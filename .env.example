# =============================================================================
# Modèle de configuration Supabase (P0-A) — SANS secret, committable.
# Copie ce fichier en `.env` (gitignored) et remplis les vraies valeurs.
# Tu trouves toutes ces valeurs dans le dashboard Supabase de ton projet :
#   Project Settings → API   (URL + clés anon/service_role)
#   Project Settings → Database → Connection string (URI)  (DB URL)
# =============================================================================

# URL publique de ton projet (Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Clé "anon" : publique, sûre côté navigateur (Settings → API → Project API keys → anon public)
SUPABASE_ANON_KEY=

# Clé "service_role" : SECRÈTE, accès total (bypass RLS). JAMAIS dans le navigateur, JAMAIS commitée.
SUPABASE_SERVICE_ROLE_KEY=

# Connexion directe Postgres (Settings → Database → Connection string → URI). SECRÈTE.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
