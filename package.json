{
  "name": "immotrack",
  "version": "1.0.0",
  "description": "App web vanilla JS de gestion locative immobilière (offline-first + Drive sync)",
  "main": "sw.js",
  "directories": {
    "doc": "docs",
    "test": "__tests__"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:rls": "vitest run --config supabase/tests/vitest.rls.config.mjs",
    "check:rls": "node scripts/check-rls-coverage.mjs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "dotenv": "^17.4.2",
    "marked": "^18.0.3",
    "pg": "^8.21.0",
    "supabase": "^2.105.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "immobilier",
    "gestion-locative",
    "vanilla-js",
    "offline-first"
  ],
  "author": "Didier Keller",
  "license": "ISC",
  "type": "module"
}
