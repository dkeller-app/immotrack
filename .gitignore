# =============================================================================
# IMMOTRACK — .gitignore
# Repo GitHub PUBLIC → tout ce qui contient des données réelles doit être bloqué
# =============================================================================

# ─── Dépendances Node ───
node_modules/
package-lock.json

# ─── Builds & caches ───
*.log
.DS_Store
Thumbs.db
*.tmp
*.bak
~$*

# ─── Worktrees Claude (isolés, ne pas commiter) ───
.claude/worktrees/
.claude/settings.local.json

# ─── File de coordination des commits index.html (pur local, jamais versionné) ───
# Gérée par la session maître. Voir docs/INDEX-COMMIT-PROTOCOL.md
.index-queue/

# ─── Secrets Supabase (repo public → JAMAIS commiter) ───
# .env contient service_role + URL DB = accès TOTAL bypass RLS. .env.example reste safe.
.env
.env.local
# ─── Artefacts CLI Supabase (générés, non versionnés) ───
supabase/.temp/
supabase/.branches/

# ─── IDE ───
.vscode/
.idea/

# =============================================================================
# 🚫 PROTECTION DONNÉES UTILISATEUR (NE JAMAIS PUSHER)
# Le repo est public — tout PDF/xlsx/photo perso de l'app fuiterait.
# =============================================================================

# ─── Documents binaires (templates baux, quittances, EDL, audits, business) ───
*.pdf
*.xlsx
*.xls
*.xlsm
*.docx
*.doc
*.pptx
*.ppt

# ─── Photos sources (EDL, biens, etc.) ───
*.HEIC
*.heic

# ─── Dossiers de données app ───
Sauvegardes/
backups/
EDL*/
"test bail/"
test_bail/
"Actes*.pdf"
"Quittance*.pdf"

# ─── Backups historiques d'index.html ───
# (pas de guillemets en gitignore — les espaces sont literaux)
index_*.html
index - *.html
index -*.html
index *.html
index-AS*
!index.html
!index-test.html

# ─── Fichiers de test divers ───
_check.js
apply_new_row.bat

# =============================================================================
# ✅ EXCEPTIONS — fichiers SAFE à pusher
# =============================================================================

# Screenshots mockups (assets pour partager visuels via GitHub)
!docs/strategie/dashboard-mockups/_screenshots/**

# Diagrammes audit (Mermaid sources + PNG rendus, pas de données perso)
!docs/audit/diagrams/**
actes/
